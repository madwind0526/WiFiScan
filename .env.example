# WifiScan local configuration — copy this file to `.env` and fill in values.
# `.env` is gitignored and never committed. Values here are read at runtime by
# the read-only router connector; the password is never stored in code or sent
# anywhere.

# Router admin password (required to read the DHCP client list).
WIFISCAN_ROUTER_PW=

# Router admin id (optional, defaults to "admin").
WIFISCAN_ROUTER_USER=admin

# Router address (optional, defaults to the detected gateway, e.g. 192.168.0.1).
WIFISCAN_ROUTER_HOST=
